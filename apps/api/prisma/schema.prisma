generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum InventoryTransactionType {
  IN
  OUT
  ADJUSTMENT
}

// ─── Identity & Access ────────────────────────────────────────────────────────

/// Application roles. Permissions are enforced in application code (RBAC map),
/// not as a separate permission table — keeps the schema simple while remaining
/// explicit and auditable in auth middleware.
model Role {
  id        String   @id @default(cuid())
  name      String   @unique /// SUPER_ADMIN | ADMIN | STAFF
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

model User {
  id            String                  @id @default(cuid())
  name          String
  email         String                  @unique
  password      String /// bcrypt hash — never store plaintext
  roleId        String
  role          Role                    @relation(fields: [roleId], references: [id])
  isActive      Boolean                 @default(true)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  transactions  InventoryTransaction[]
  refreshTokens RefreshToken[]

  @@index([roleId])
  @@index([isActive])
  @@map("users")
}

/// Persisted refresh sessions enable logout/revoke. Store only a hash of the token.
model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userAgent String?
  ipAddress String?

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── Catalog ─────────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model Supplier {
  id        String    @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([name])
  @@map("suppliers")
}

model Product {
  id           String                  @id @default(cuid())
  sku          String                  @unique
  name         String
  description  String?
  price        Decimal                 @db.Decimal(12, 2)
  stock        Int                     @default(0)
  minimumStock Int                     @default(0)
  categoryId   String
  supplierId   String
  status       ProductStatus           @default(ACTIVE)
  category     Category                @relation(fields: [categoryId], references: [id])
  supplier     Supplier                @relation(fields: [supplierId], references: [id])
  transactions InventoryTransaction[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([categoryId])
  @@index([supplierId])
  @@index([status])
  @@index([stock, minimumStock]) /// supports low-stock report queries
  @@map("products")
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model InventoryTransaction {
  id        String                    @id @default(cuid())
  type      InventoryTransactionType
  quantity  Int
  note      String?
  productId String
  userId    String
  product   Product                   @relation(fields: [productId], references: [id])
  user      User                      @relation(fields: [userId], references: [id])
  createdAt DateTime                  @default(now())

  @@index([productId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("inventory_transactions")
}
