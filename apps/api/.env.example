# Server
NODE_ENV=development
PORT=4000

# CORS — Next.js web app origin
WEB_ORIGIN=http://localhost:3000

# PostgreSQL (local install — not Docker)
# Format: postgresql://USER:PASSWORD@localhost:5432/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ims_inventory?schema=public"

# Auth — use long random secrets in real deployments (never commit real secrets)
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars!!"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars!"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
